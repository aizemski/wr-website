---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Highlight {
	title: string;
	description: string;
}

interface PainPoint {
	title: string;
	description: string;
}

interface Outcome {
	title: string;
	description: string;
}

interface ProcessStep {
	step: string;
	title: string;
	description: string;
}

interface RelatedService {
	href: string;
	label: string;
	description: string;
}

interface RelatedAudience {
	href: string;
	label: string;
}

interface FaqItem {
	question: string;
	answer: string;
}

interface Props {
	title: string;
	description: string;
	eyebrow: string;
	headline: string;
	subheadline: string;
	painIntro: string;
	painPoints: PainPoint[];
	outcomesIntro: string;
	outcomes: Outcome[];
	highlights: Highlight[];
	process: ProcessStep[];
	goodFit: string[];
	relatedServices: RelatedService[];
	relatedAudiences: RelatedAudience[];
	faq: FaqItem[];
}

const {
	title,
	description,
	eyebrow,
	headline,
	subheadline,
	painIntro,
	painPoints,
	outcomesIntro,
	outcomes,
	highlights,
	process,
	goodFit,
	relatedServices,
	relatedAudiences,
	faq,
} = Astro.props;
---

<BaseLayout {title} {description}>
	<div class="page-shell">
		<section class="relative overflow-hidden py-20 sm:py-28 md:py-32">
			<div
				class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(0,103,255,0.12),transparent_55%)] dark:bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(0,103,255,0.16),transparent_55%)]"
				aria-hidden="true"
			/>
			<div class="page-container relative">
				<a
					href="/#who-we-help"
					class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-body transition-colors duration-300 hover:text-[#0067FF] dark:hover:text-[#3d8fff]"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M19 12H5M12 19l-7-7 7-7" />
					</svg>
					Who we help
				</a>
				<div class="mx-auto max-w-3xl">
					<p class="text-xs font-semibold uppercase tracking-wider text-[#0067FF] dark:text-[#3d8fff]">{eyebrow}</p>
					<h1
						class="font-[family-name:var(--font-display)] text-heading mt-3 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl md:text-5xl"
					>
						{headline}
					</h1>
					<p class="text-body mt-6 text-lg leading-relaxed">{subheadline}</p>
					<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
						<a href="/contact" class="btn-primary px-7 py-3.5">Book a discovery call</a>
						<a
							href="/about"
							class="text-center text-sm font-medium text-body transition-colors hover:text-[#0067FF] dark:hover:text-[#3d8fff] sm:text-left"
						>
							About White Raven →
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-12 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						Sound familiar?
					</h2>
					<p class="text-body mt-4 leading-relaxed">{painIntro}</p>
				</div>
				<ul class="grid gap-6 md:grid-cols-3" role="list">
					{
						painPoints.map((item) => (
							<li class="card-glass p-7">
								<h3 class="font-[family-name:var(--font-display)] text-heading text-base font-semibold">
									{item.title}
								</h3>
								<p class="text-body mt-3 text-sm leading-relaxed">{item.description}</p>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-14 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						What you gain
					</h2>
					<p class="text-body mt-4 leading-relaxed">{outcomesIntro}</p>
				</div>
				<ul class="grid gap-6 sm:grid-cols-2" role="list">
					{
						outcomes.map((item) => (
							<li class="flex gap-4">
								<span
									class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#0067FF]/10 text-sm font-semibold text-[#0067FF]"
									aria-hidden="true"
								>
									✓
								</span>
								<div>
									<h3 class="font-[family-name:var(--font-display)] text-heading text-base font-semibold">
										{item.title}
									</h3>
									<p class="text-body mt-2 text-sm leading-relaxed">{item.description}</p>
								</div>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-14 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						How we help
					</h2>
					<p class="text-body mt-4">
						Practical delivery tuned to your stage—not a one-size-fits-all playbook.
					</p>
				</div>
				<ul class="grid gap-6 sm:grid-cols-2 lg:gap-8" role="list">
					{
						highlights.map((item) => (
							<li class="card-glass p-8">
								<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-[#0067FF]/15 text-[#0067FF]">
									<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
										<path d="M20 6 9 17l-5-5" />
									</svg>
								</div>
								<h3 class="font-[family-name:var(--font-display)] text-heading text-lg font-semibold">
									{item.title}
								</h3>
								<p class="text-body mt-3 text-sm leading-relaxed">{item.description}</p>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-14 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						How we work together
					</h2>
					<p class="text-body mt-4">
						A clear path from first conversation to software in production—with you in the loop the whole way.
					</p>
				</div>
				<ol class="mx-auto max-w-3xl space-y-8" role="list">
					{
						process.map((item) => (
							<li class="flex gap-5 sm:gap-6">
								<span
									class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#0067FF] text-sm font-bold text-white"
									aria-hidden="true"
								>
									{item.step}
								</span>
								<div>
									<h3 class="font-[family-name:var(--font-display)] text-heading text-lg font-semibold">
										{item.title}
									</h3>
									<p class="text-body mt-2 text-sm leading-relaxed sm:text-base">{item.description}</p>
								</div>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)] lg:gap-16 lg:items-start">
					<div class="mb-10 lg:mb-0">
						<h2
							class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
						>
							A good fit when…
						</h2>
						<p class="text-body mt-4 leading-relaxed">
							These situations are where we deliver the most value for teams like yours.
						</p>
					</div>
					<ul class="space-y-4" role="list">
						{
							goodFit.map((item) => (
								<li class="card-glass flex gap-4 p-5 sm:p-6">
									<span class="mt-0.5 text-[#0067FF]" aria-hidden="true">→</span>
									<p class="text-body text-sm leading-relaxed sm:text-base">{item}</p>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-10 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						Relevant services
					</h2>
					<p class="text-body mt-4">Start with the capabilities that map closest to your goals.</p>
				</div>
				<ul class="grid gap-5 sm:grid-cols-2 lg:max-w-4xl" role="list">
					{
						relatedServices.map((service) => (
							<li>
								<a
									href={service.href}
									class="card-glass group flex flex-col p-6 transition-all duration-300 hover:border-[#0067FF]/40 sm:p-7"
								>
									<h3 class="font-[family-name:var(--font-display)] text-heading text-lg font-semibold group-hover:text-[#0067FF] dark:group-hover:text-[#3d8fff]">
										{service.label}
									</h3>
									<p class="text-body mt-2 flex-1 text-sm leading-relaxed">{service.description}</p>
									<span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[#0067FF]">
										View service
										<svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
											<path d="M5 12h14M13 6l6 6-6 6" />
										</svg>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-16 sm:py-20">
			<div class="page-container">
				<p class="text-body text-center text-sm">
					Also exploring other paths?
					{
						relatedAudiences.map((item, i) => (
							<>
								{i > 0 && <span aria-hidden="true"> · </span>}
								<a href={item.href} class="font-medium text-[#0067FF] hover:underline dark:text-[#3d8fff]">
									{item.label}
								</a>
							</>
						))
					}
				</p>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-12 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						Common questions
					</h2>
				</div>
				<div class="mx-auto max-w-3xl divide-y divide-[var(--border-color)]">
					{
						faq.map((item) => (
							<details class="group py-6 first:pt-0">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-[family-name:var(--font-display)] text-base font-semibold text-heading marker:content-none [&::-webkit-details-marker]:hidden">
									{item.question}
									<span class="shrink-0 text-[#0067FF] transition-transform group-open:rotate-45" aria-hidden="true">
										+
									</span>
								</summary>
								<p class="text-body mt-4 pr-8 text-sm leading-relaxed sm:text-base">{item.answer}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-24">
			<div class="page-container text-center">
				<h2
					class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
				>
					Let&apos;s talk about your next step
				</h2>
				<p class="text-body mx-auto mt-4 max-w-xl">
					Share where you are today and what success looks like. We respond within one business day—no pitch deck
					required.
				</p>
				<a href="/contact" class="btn-primary mt-8 inline-flex">Book a discovery call</a>
			</div>
		</section>
	</div>
</BaseLayout>
