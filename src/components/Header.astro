---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import NavServicesMenu from './NavServicesMenu.astro';
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [{ href: '/blog', label: 'Blog' }];

const mobileServiceLinks = [
	{ href: '/services/product-engineering', label: 'Product Engineering' },
	{ href: '/services/applied-ai', label: 'Applied AI' },
	{ href: '/services/workflow-automation', label: 'Workflow Automation' },
	{ href: '/services/cloud-architecture', label: 'Cloud & DevOps' },
];
---

<header class="site-header glass-nav sticky top-0 z-50 overflow-visible">
	<nav
		class="page-container flex h-16 items-center justify-between gap-6 overflow-visible lg:h-[4.25rem]"
		aria-label="Main navigation"
	>
		<a
			href="/"
			class="display-heading group flex min-w-0 shrink items-center gap-2.5 text-base tracking-tight text-foreground transition-opacity duration-300 hover:opacity-90 sm:text-lg"
		>
			<img
				src="/wr-logo.png"
				alt=""
				width="32"
				height="32"
				class="h-8 w-8 shrink-0 object-contain transition-transform duration-300 group-hover:scale-105"
				aria-hidden="true"
			/>
			<span class="truncate">{SITE_TITLE}</span>
		</a>

		<div class="relative hidden items-center gap-0.5 overflow-visible md:flex">
			<HeaderLink href="/">Home</HeaderLink>
			<div class="px-0.5">
				<NavServicesMenu />
			</div>
			{navLinks.map(({ href, label }) => (
				<HeaderLink href={href}>{label}</HeaderLink>
			))}
		</div>

		<div class="flex shrink-0 items-center gap-2 sm:gap-3">
			<a href="/contact" class="btn-primary hidden px-5 py-2.5 text-xs sm:inline-flex sm:text-sm">
				Let&apos;s Discuss Your Vision
			</a>
			<ThemeToggle />
			<button
				type="button"
				id="mobile-menu-toggle"
				class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface-elevated/80 text-muted transition-colors duration-300 hover:border-[#0067FF]/40 hover:text-foreground focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0067FF] md:hidden"
				aria-expanded="false"
				aria-controls="mobile-menu"
				aria-label="Open menu"
			>
				<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
					<path d="M4 7h16M4 12h16M4 17h16" />
				</svg>
			</button>
		</div>
	</nav>

	<div id="mobile-menu" class="hidden border-t border-border bg-surface-elevated md:hidden" hidden>
		<div class="page-container flex flex-col gap-1 py-4">
			<HeaderLink href="/" class="mobile-nav-link block w-full px-4 py-3">Home</HeaderLink>

			<div class="px-4 py-2">
				<p class="mb-2 text-xs font-semibold uppercase tracking-wider text-muted">Services</p>
				<ul class="space-y-0.5">
					{
						mobileServiceLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="mobile-nav-link block rounded-lg px-3 py-2.5 text-sm font-medium text-muted transition-colors duration-300 hover:bg-slate-100 hover:text-foreground dark:hover:bg-white/5 dark:hover:text-white"
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			{navLinks.map(({ href, label }) => (
				<HeaderLink href={href} class="mobile-nav-link block w-full px-4 py-3">{label}</HeaderLink>
			))}

			<div class="px-4 pt-2">
				<a href="/contact" class="btn-primary w-full justify-center">Let&apos;s Discuss Your Vision</a>
			</div>
		</div>
	</div>
</header>

<script>
	let menuController: AbortController | undefined;

	function setupMobileMenu() {
		menuController?.abort();
		menuController = new AbortController();
		const { signal } = menuController;

		const menuToggle = document.getElementById('mobile-menu-toggle');
		const mobileMenu = document.getElementById('mobile-menu');
		const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

		const closeMenu = () => {
			mobileMenu?.classList.add('hidden');
			mobileMenu?.setAttribute('hidden', '');
			menuToggle?.setAttribute('aria-expanded', 'false');
			menuToggle?.setAttribute('aria-label', 'Open menu');
		};

		const openMenu = () => {
			mobileMenu?.classList.remove('hidden');
			mobileMenu?.removeAttribute('hidden');
			menuToggle?.setAttribute('aria-expanded', 'true');
			menuToggle?.setAttribute('aria-label', 'Close menu');
		};

		menuToggle?.addEventListener(
			'click',
			() => {
				const isHidden = mobileMenu?.classList.contains('hidden');
				if (isHidden) openMenu();
				else closeMenu();
			},
			{ signal },
		);

		mobileLinks.forEach((link) => link.addEventListener('click', closeMenu, { signal }));

		document.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'Escape') closeMenu();
			},
			{ signal },
		);
	}

	setupMobileMenu();
	document.addEventListener('astro:page-load', setupMobileMenu);
</script>
