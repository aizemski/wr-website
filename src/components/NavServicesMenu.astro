---
const serviceLinks = [
	{
		href: '/services/product-engineering',
		label: 'Product Engineering',
		description: 'MVPs and legacy modernization',
	},
	{
		href: '/services/applied-ai',
		label: 'Applied AI',
		description: 'LLMs, RAG, and predictive models',
	},
	{
		href: '/services/workflow-automation',
		label: 'Workflow Automation',
		description: 'Portals, PWAs, and data pipelines',
	},
	{
		href: '/services/cloud-architecture',
		label: 'Cloud & DevOps',
		description: 'AWS serverless and CI/CD',
	},
];

const pathname = Astro.url.pathname;
const isServicesSection = pathname.startsWith('/services');
---

<div class="nav-services group relative z-50" data-nav-services>
	<button
		type="button"
		class:list={[
			'flex cursor-default items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-colors duration-300 group-hover:text-slate-900 group-focus-within:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0067FF] dark:group-hover:text-white dark:group-focus-within:text-white',
			isServicesSection
				? 'bg-[#0067FF]/10 text-[#0067FF] ring-1 ring-[#0067FF]/30 dark:bg-[#0067FF]/15 dark:text-white dark:ring-[#0067FF]/40'
				: 'text-slate-600 dark:text-slate-300',
		]}
		aria-haspopup="true"
		tabindex="0"
	>
		Services
		<svg
			class="h-4 w-4 shrink-0 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			aria-hidden="true"
		>
			<path d="M6 9l6 6 6-6" />
		</svg>
	</button>

	<div
		class="services-dropdown pointer-events-none invisible absolute left-0 top-full z-50 w-[min(100vw-2.5rem,20rem)] pt-2 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 lg:left-1/2 lg:w-80 lg:-translate-x-1/2"
		role="menu"
	>
		<div
			class="rounded-2xl border border-slate-200 bg-white p-2 shadow-[0_16px_48px_rgba(15,23,42,0.12)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-900 dark:shadow-[0_16px_48px_rgba(0,0,0,0.5)]"
		>
			<ul class="space-y-0.5" role="none">
				{
					serviceLinks.map((item) => (
						<li role="none">
							<a
								href={item.href}
								role="menuitem"
								class="group/item block rounded-xl px-3 py-2.5 transition-colors duration-300 hover:bg-[#0067FF]/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#0067FF]"
							>
								<span class="block text-sm font-semibold text-slate-900 group-hover/item:text-[#0067FF] dark:text-white dark:group-hover/item:text-[#3d8fff]">
									{item.label}
								</span>
								<span class="mt-0.5 block text-xs text-slate-500 group-hover/item:text-slate-600 dark:text-slate-400 dark:group-hover/item:text-slate-300">
									{item.description}
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</div>

<style>
	@media (prefers-reduced-motion: reduce) {
		.nav-services .services-dropdown {
			transition: none;
		}
	}
</style>
