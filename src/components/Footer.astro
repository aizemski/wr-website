---
import { CONTACT_EMAIL, SITE_TITLE } from '../consts';

const year = new Date().getFullYear();

const footerLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/#who-we-help', label: 'Who we help' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/about', label: 'About' },
	{ href: '/contact', label: 'Contact' },
];

const serviceLinks = [
	{ href: '/services/product-engineering', label: 'Product Engineering' },
	{ href: '/services/applied-ai', label: 'Applied AI' },
	{ href: '/services/workflow-automation', label: 'Workflow Automation' },
	{ href: '/services/cloud-architecture', label: 'Cloud & DevOps' },
];
---

<footer class="site-footer glass-footer mt-auto">
	<div class="page-container py-14 md:py-16">
		<div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr] md:gap-10 lg:gap-16">
			<div class="max-w-sm space-y-4">
				<a href="/" class="display-heading inline-flex items-center gap-2.5 text-lg text-foreground">
					<img
						src="/wr-logo.png"
						alt=""
						width="32"
						height="32"
						class="h-8 w-8 shrink-0 object-contain"
						aria-hidden="true"
					/>
					{SITE_TITLE}
				</a>
				<p class="text-sm leading-relaxed text-body">
					We build web apps, AI systems, and cloud infrastructure that help teams ship faster and grow revenue.
				</p>
				<a href="/contact" class="btn-primary inline-flex text-sm">
					Let&apos;s Discuss Your Vision
				</a>
			</div>

			<nav aria-label="Company">
				<p class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted">Company</p>
				<ul class="space-y-2.5">
					{
						footerLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="text-sm text-body transition-colors duration-300 hover:text-[#0067FF] dark:hover:text-[#3d8fff]"
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<nav aria-label="Services">
				<p class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted">Services</p>
				<ul class="space-y-2.5">
					{
						serviceLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="text-sm text-body transition-colors duration-300 hover:text-[#0067FF] dark:hover:text-[#3d8fff]"
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>

		<div
			class="mt-12 flex flex-col gap-3 border-t border-theme pt-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
		>
			<p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>
			<p>
				<a href={`mailto:${CONTACT_EMAIL}`} class="text-body transition-colors hover:text-[#0067FF] dark:hover:text-[#3d8fff]">
					{CONTACT_EMAIL}
				</a>
			</p>
		</div>
	</div>
</footer>
