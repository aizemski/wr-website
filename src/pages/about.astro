---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CORE_STACK } from '../consts';

const principles = [
	{
		title: 'Production over theater',
		description:
			'We ship software people use—not decks, not throwaway demos. Every deliverable is built to run in your environment with tests, docs, and a handoff plan.',
	},
	{
		title: 'Senior engineers in the room',
		description:
			'You work directly with people who have shipped MVPs, migrations, and AI systems before. No bait-and-switch to juniors after the contract is signed.',
	},
	{
		title: 'Your team owns what we build',
		description:
			'We document architecture, run pairing sessions, and leave repos your hires can extend. Our goal is momentum for you, not a permanent dependency.',
	},
];

const pillars = [
	{
		href: '/services/product-engineering',
		title: 'Product engineering',
		description: 'React, Next.js, and APIs built for velocity today and scale tomorrow.',
	},
	{
		href: '/services/applied-ai',
		title: 'Applied AI',
		description: 'LLMs and ML that plug into real workflows—with guardrails and monitoring.',
	},
	{
		href: '/services/workflow-automation',
		title: 'Workflow automation',
		description: 'Portals, field apps, and pipelines that replace spreadsheet chaos.',
	},
	{
		href: '/services/cloud-architecture',
		title: 'Cloud & DevOps',
		description: 'AWS serverless, CI/CD, and observability so releases stay boring—in a good way.',
	},
];

const process = [
	{
		step: '1',
		title: 'Listen and scope',
		description:
			'We start with your goals, constraints, and timeline—not a generic statement of work. Most engagements get a clear phased plan within days.',
	},
	{
		step: '2',
		title: 'Ship in the open',
		description:
			'Weekly demos of working software. You see progress, reprioritize when the market shifts, and never wonder what we did last sprint.',
	},
	{
		step: '3',
		title: 'Harden and launch',
		description:
			'Auth, performance, security, and monitoring before go-live. We treat launch as the beginning of reliability, not the end of the project.',
	},
	{
		step: '4',
		title: 'Transfer knowledge',
		description:
			'Runbooks, architecture notes, and pairing so your team can operate and extend what we delivered without starting over.',
	},
];

const audiences = [
	{
		href: '/for/startup-founders',
		label: 'Startup founders',
		description: 'MVPs and architecture that survive your first wave of real users.',
	},
	{
		href: '/for/operations-leaders',
		label: 'Operations leaders',
		description: 'Automation, portals, and AI that remove manual work from daily ops.',
	},
	{
		href: '/for/enterprise-engineering',
		label: 'Enterprise engineering',
		description: 'Modernization, cloud, and delivery practices that pass security review.',
	},
	{
		href: '/for/small-business',
		label: 'Small business owners',
		description: 'Tailored ops software when spreadsheets and generic SaaS stop scaling.',
	},
];

const faq = [
	{
		question: 'How big is White Raven?',
		answer:
			'We are a focused studio—not a 200-person agency. That keeps every client close to senior engineers and keeps our teams small enough to move fast.',
	},
	{
		question: 'Where are you based?',
		answer:
			'We work remotely with clients across North America and Europe. Collaboration happens in your tools—Slack, GitHub, and your standup rhythm.',
	},
	{
		question: 'What engagements do you avoid?',
		answer:
			'Staff aug without outcomes, pure advisory with no build, and AI projects with no owner on your side. We say no when we cannot deliver measurable value.',
	},
	{
		question: 'How do we get started?',
		answer:
			'Share your project on our contact page or email hello@whiteraven.app. We reply within one business day with next steps—usually a short discovery call.',
	},
];
---

<BaseLayout
	title="About"
	description="White Raven is a software studio for founders and operators who need senior engineering across React, Python, AWS, and production AI."
>
	<div class="page-shell">
		<section class="relative overflow-hidden py-20 sm:py-28 md:py-32">
			<div
				class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(0,103,255,0.1),transparent_55%)] dark:bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(0,103,255,0.14),transparent_55%)]"
				aria-hidden="true"
			/>
			<div class="page-container relative">
				<div class="mx-auto max-w-3xl">
					<p class="text-xs font-semibold uppercase tracking-wider text-[#0067FF] dark:text-[#3d8fff]">About White Raven</p>
					<h1
						class="font-[family-name:var(--font-display)] text-heading mt-3 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl md:text-5xl"
					>
						Senior engineering, end to end
					</h1>
					<p class="text-body mt-6 text-lg leading-relaxed">
						White Raven is a software studio for founders and operators who need production-grade work, not slide decks. We
						build customer-facing products, AI systems, and cloud platforms your team can run long after we step back.
					</p>
					<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
						<a href="/contact" class="btn-primary px-7 py-3.5">Book a discovery call</a>
						<a
							href="/#services"
							class="text-center text-sm font-medium text-body transition-colors hover:text-[#0067FF] dark:hover:text-[#3d8fff] sm:text-left"
						>
							See what we build →
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-14 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						What we stand for
					</h2>
					<p class="text-body mt-4 leading-relaxed">
						Three principles guide every engagement. They are simple on purpose—and we hold ourselves to them.
					</p>
				</div>
				<ul class="grid gap-6 md:grid-cols-3" role="list">
					{
						principles.map((item) => (
							<li class="card-glass p-7 sm:p-8">
								<h3 class="font-[family-name:var(--font-display)] text-heading text-lg font-semibold">{item.title}</h3>
								<p class="text-body mt-3 text-sm leading-relaxed">{item.description}</p>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-start">
					<div>
						<h2
							class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
						>
							Why teams hire us
						</h2>
						<p class="text-body mt-4 leading-relaxed">
							Most clients come to us when speed and quality are both non-negotiable. They have tried the alternatives—and
							need a partner who can execute without babysitting.
						</p>
					</div>
					<ul class="mt-10 space-y-5 lg:mt-0" role="list">
						<li class="flex gap-4">
							<span class="mt-1 text-[#0067FF]" aria-hidden="true">→</span>
							<p class="text-body text-sm leading-relaxed sm:text-base">
								<strong class="text-heading font-semibold">You need to ship in weeks,</strong> not quarters, without cutting
								corners that force a rewrite later.
							</p>
						</li>
						<li class="flex gap-4">
							<span class="mt-1 text-[#0067FF]" aria-hidden="true">→</span>
							<p class="text-body text-sm leading-relaxed sm:text-base">
								<strong class="text-heading font-semibold">Your stack is aging</strong> and leadership wants modernization
								without freezing the roadmap.
							</p>
						</li>
						<li class="flex gap-4">
							<span class="mt-1 text-[#0067FF]" aria-hidden="true">→</span>
							<p class="text-body text-sm leading-relaxed sm:text-base">
								<strong class="text-heading font-semibold">AI is on the roadmap</strong> but pilots stall before they reach
								the workflows operators use daily.
							</p>
						</li>
						<li class="flex gap-4">
							<span class="mt-1 text-[#0067FF]" aria-hidden="true">→</span>
							<p class="text-body text-sm leading-relaxed sm:text-base">
								<strong class="text-heading font-semibold">Infrastructure is the bottleneck</strong>—deploys are scary, bills
								creep up, and outages still surprise the team.
							</p>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-14 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						What we build
					</h2>
					<p class="text-body mt-4">
						One studio across product, AI, automation, and cloud—so you do not juggle four vendors who never talk.
					</p>
				</div>
				<ul class="grid gap-5 sm:grid-cols-2" role="list">
					{
						pillars.map((item) => (
							<li>
								<a
									href={item.href}
									class="card-glass group flex flex-col p-6 transition-all duration-300 hover:border-[#0067FF]/40 sm:p-7"
								>
									<h3 class="font-[family-name:var(--font-display)] text-heading text-lg font-semibold group-hover:text-[#0067FF] dark:group-hover:text-[#3d8fff]">
										{item.title}
									</h3>
									<p class="text-body mt-2 flex-1 text-sm leading-relaxed">{item.description}</p>
									<span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[#0067FF]">
										View service
										<svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
											<path d="M5 12h14M13 6l6 6-6 6" />
										</svg>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-14 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						How we work
					</h2>
					<p class="text-body mt-4">
						A straightforward rhythm from first call to handoff. No black boxes, no surprise invoices at the end of the
						quarter.
					</p>
				</div>
				<ol class="mx-auto max-w-3xl space-y-8" role="list">
					{
						process.map((item) => (
							<li class="flex gap-5 sm:gap-6">
								<span
									class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#0067FF] text-sm font-bold text-white"
									aria-hidden="true"
								>
									{item.step}
								</span>
								<div>
									<h3 class="font-[family-name:var(--font-display)] text-heading text-lg font-semibold">{item.title}</h3>
									<p class="text-body mt-2 text-sm leading-relaxed sm:text-base">{item.description}</p>
								</div>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-10 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						Who we help
					</h2>
					<p class="text-body mt-4">Different stages, same standard: software that works in production.</p>
				</div>
				<ul class="grid gap-5 sm:grid-cols-3" role="list">
					{
						audiences.map((item) => (
							<li>
								<a
									href={item.href}
									class="card-glass group flex h-full flex-col p-6 transition-all duration-300 hover:border-[#0067FF]/40 sm:p-7"
								>
									<h3 class="font-[family-name:var(--font-display)] text-heading text-base font-semibold group-hover:text-[#0067FF] dark:group-hover:text-[#3d8fff]">
										{item.label}
									</h3>
									<p class="text-body mt-2 flex-1 text-sm leading-relaxed">{item.description}</p>
									<span class="mt-5 text-sm font-semibold text-[#0067FF]">Learn more →</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-28">
			<div class="page-container">
				<div class="card-glass mx-auto max-w-3xl p-8 sm:p-10 md:p-12">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						The stack we ship with
					</h2>
					<p class="text-body mt-4 leading-relaxed">
						We choose boring, proven tools and use them well. That keeps your team hiring-friendly and your systems
						maintainable.
					</p>
					<ul class="mt-8 flex flex-wrap gap-3" role="list">
						{
							CORE_STACK.map((tool) => (
								<li>
									<span class="badge-pill">{tool}</span>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</section>

		<section class="border-t border-theme surface-muted py-20 sm:py-28">
			<div class="page-container">
				<div class="mx-auto mb-12 max-w-2xl">
					<h2
						class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
					>
						Common questions
					</h2>
				</div>
				<div class="mx-auto max-w-3xl divide-y divide-[var(--border-color)]">
					{
						faq.map((item) => (
							<details class="group py-6 first:pt-0">
								<summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-[family-name:var(--font-display)] text-base font-semibold text-heading marker:content-none [&::-webkit-details-marker]:hidden">
									{item.question}
									<span class="shrink-0 text-[#0067FF] transition-transform group-open:rotate-45" aria-hidden="true">
										+
									</span>
								</summary>
								<p class="text-body mt-4 pr-8 text-sm leading-relaxed sm:text-base">{item.answer}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<section class="border-t border-theme py-20 sm:py-24">
			<div class="page-container text-center">
				<h2
					class="font-[family-name:var(--font-display)] text-heading text-2xl font-semibold tracking-tight md:text-3xl"
				>
					Let&apos;s talk about your next project
				</h2>
				<p class="text-body mx-auto mt-4 max-w-xl">
					Tell us what you are building and where you are stuck. We respond within one business day.
				</p>
				<a href="/contact" class="btn-primary mt-8 inline-flex">Book a discovery call</a>
			</div>
		</section>
	</div>
</BaseLayout>
