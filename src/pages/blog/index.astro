---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import InsightsListing, { type FilterChip } from '../../components/InsightsListing.astro';
import {
	BLOG_TAG_SLUGS,
	filterPublishedInsights,
	getBlogTagMeta,
	getBlogTagPath,
	sortInsightsByDate,
} from '../../utils/insights';

const posts = sortInsightsByDate(filterPublishedInsights(await getCollection('insights')));

const filterChips: FilterChip[] = BLOG_TAG_SLUGS.map((slug) => {
	const meta = getBlogTagMeta(slug);
	return {
		slug,
		label: meta.label,
		href: getBlogTagPath(slug),
		dimension: meta.dimension,
	};
});
---

<BaseLayout
	title="Blog"
	description="Practical guides on product engineering, applied AI, workflow automation, and cloud delivery—for founders, engineering leaders, and operators building production software."
>
	<div class="page-shell">
		<InsightsListing
			eyebrow="Resources"
			title="Blog"
			description="Search articles or browse by audience, service, technology, and industry. Each topic has its own page with a focused collection."
			posts={posts}
			filterChips={filterChips}
			showFeatured
			firstPageSize={5}
			postsPerPage={6}
		/>
	</div>
</BaseLayout>
