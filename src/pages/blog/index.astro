---
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUniqueTags } from '../../utils/blog';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featuredPost, ...remainingPosts] = posts;
const tags = getUniqueTags(posts);
---

<BaseLayout
	title="Blog"
	description="Practical notes on React, Python, AWS, and shipping AI systems to production from the White Raven team."
>
	<div class="page-shell">
		<section class="section-padding page-container">
			<div class="mx-auto mb-14 max-w-2xl">
				<h1 class="font-[family-name:var(--font-display)] text-heading text-4xl font-semibold tracking-tight md:text-5xl">
					Engineering notes
				</h1>
				<p class="text-body mt-5 text-lg leading-relaxed">
					What we learn building products: frontend architecture, production AI, and cloud delivery that holds up under real load.
				</p>
			</div>

			<div
				class="mb-12 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
				id="tag-filters"
				role="group"
				aria-label="Filter posts by tag"
			>
				<button
					type="button"
					data-tag="all"
					class="tag-filter shrink-0 active rounded-full border border-[#0067FF] bg-[#0067FF] px-4 py-2 text-sm font-semibold text-white transition-all duration-300"
				>
					All
				</button>
				{
					tags.map((tag) => (
						<button
							type="button"
							data-tag={tag}
							class="tag-filter shrink-0 rounded-full border border-border bg-surface-elevated px-4 py-2 text-sm font-medium text-muted transition-all duration-300 hover:border-border-strong hover:text-foreground"
						>
							{tag}
						</button>
					))
				}
			</div>

			<div class="space-y-8" id="blog-posts">
				{
					featuredPost && (
						<div class="blog-post-item" data-tags={featuredPost.data.tags.join(',')}>
							<BlogCard post={featuredPost} featured />
						</div>
					)
				}

				{
					remainingPosts.length > 0 && (
						<div class="grid gap-6 md:grid-cols-2">
							{remainingPosts.map((post) => (
								<div class="blog-post-item" data-tags={post.data.tags.join(',')}>
									<BlogCard post={post} />
								</div>
							))}
						</div>
					)
				}
			</div>

			<p id="no-posts-message" class="text-body hidden py-16 text-center">
				No posts match this tag. Try another filter.
			</p>
		</section>
	</div>
</BaseLayout>

<script>
	let filterController: AbortController | undefined;

	function setupTagFilters() {
		filterController?.abort();
		filterController = new AbortController();
		const { signal } = filterController;

		const filters = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
		const items = document.querySelectorAll<HTMLElement>('.blog-post-item');
		const emptyMessage = document.getElementById('no-posts-message');

		if (!filters.length) return;

		const activeClasses = ['bg-[#0067FF]', 'text-white', 'border-[#0067FF]', 'font-semibold'];
		const inactiveClasses = [
			'bg-surface-elevated',
			'text-muted',
			'border-border',
			'font-medium',
		];

		const setFilter = (activeTag: string) => {
			let visibleCount = 0;

			items.forEach((item) => {
				const itemTags = item.dataset.tags?.split(',') ?? [];
				const show = activeTag === 'all' || itemTags.includes(activeTag);
				item.classList.toggle('hidden', !show);
				if (show) visibleCount += 1;
			});

			emptyMessage?.classList.toggle('hidden', visibleCount > 0);

			filters.forEach((button) => {
				const isActive = button.dataset.tag === activeTag;
				button.classList.toggle('active', isActive);
				activeClasses.forEach((cls) => button.classList.toggle(cls, isActive));
				inactiveClasses.forEach((cls) => button.classList.toggle(cls, !isActive));
			});
		};

		filters.forEach((button) => {
			button.addEventListener(
				'click',
				() => setFilter(button.dataset.tag ?? 'all'),
				{ signal },
			);
		});
	}

	setupTagFilters();
	document.addEventListener('astro:page-load', setupTagFilters);
</script>
