---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactMultiStepForm from '../components/ContactMultiStepForm.astro';
import { CONTACT_EMAIL } from '../consts';

const steps = [
	{ title: 'About you', detail: 'Name and email so we can reply' },
	{ title: 'Your goals', detail: 'Pick the services that fit your project' },
	{ title: 'Project details', detail: 'Timeline and a short overview' },
];
---

<BaseLayout
	title="Contact"
	description="Tell White Raven about your product, AI, automation, or cloud project. We reply within one business day."
>
	<div class="page-shell">
		<section class="section-padding page-container">
			<div
				class="mx-auto grid max-w-5xl grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)] lg:items-start lg:gap-14 xl:gap-16"
			>
				<div class="order-2 lg:order-1 lg:sticky lg:top-28">
					<p class="text-xs font-semibold uppercase tracking-wider text-[#0067FF]">Contact</p>
					<h1
						class="font-[family-name:var(--font-display)] text-heading mt-3 text-3xl font-semibold tracking-tight md:text-4xl"
					>
						Tell us about your project
					</h1>
					<p class="text-body mt-4 max-w-md leading-relaxed">
						Three short steps. We read every submission personally and reply within one business day—usually sooner.
					</p>

					<ol class="mt-8 space-y-4 border-t border-theme pt-8" aria-label="How it works">
						{
							steps.map((item, i) => (
								<li class="flex gap-4">
									<span
										class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#0067FF]/10 text-sm font-semibold text-[#0067FF]"
										aria-hidden="true"
									>
										{i + 1}
									</span>
									<div>
										<p class="text-heading text-sm font-semibold">{item.title}</p>
										<p class="text-body mt-0.5 text-sm">{item.detail}</p>
									</div>
								</li>
							))
						}
					</ol>

					<div class="surface-muted mt-8 rounded-2xl border border-theme p-5">
						<p class="text-heading text-sm font-semibold">Prefer email?</p>
						<p class="text-body mt-1 text-sm leading-relaxed">
							Skip the form and write directly—we&apos;ll treat it the same way.
						</p>
						<a
							href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent('Project inquiry')}`}
							class="mt-3 inline-flex text-sm font-medium text-[#0067FF] transition-colors hover:text-[#0058d9] dark:text-[#3d8fff] dark:hover:text-white"
						>
							{CONTACT_EMAIL}
						</a>
					</div>
				</div>

				<section
					id="contact-form"
					class="card-glass order-1 p-6 sm:p-8 md:p-10 lg:order-2"
					aria-labelledby="contact-form-heading"
				>
					<h2
						id="contact-form-heading"
						class="font-[family-name:var(--font-display)] text-heading mb-6 text-xl font-semibold tracking-tight sm:text-2xl"
					>
						Project inquiry form
					</h2>
					<ContactMultiStepForm contactEmail={CONTACT_EMAIL} />
				</section>
			</div>
		</section>
	</div>
</BaseLayout>
